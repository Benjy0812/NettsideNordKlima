{
  "languages": {
    "JavaScript": {
      "tab_size": 2
    },
    "SCSS": {
      "tab_size": 2
    },
    "HTML": {
      "tab_size": 2
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": ["class=\"([^\"]*)\""]
        }
      }
    }
  }
}
